# =============================================================================
# hosts-extra.yaml — дополнительные Vault политики, роли и ESO secrets
# =============================================================================
# Этот файл НЕ входит в git (добавлен в .gitignore).
# Скопируй этот шаблон: cp hosts-extra.yaml.example hosts-extra.yaml
#
# Использование:
#   ansible-playbook -i hosts.yaml -i hosts-extra.yaml playbook-app/vault-policy-sync.yaml
#
# Правила именования:
#   - Имена политик/ролей НЕ должны совпадать с именами, выводимыми из
#     eso_vault_integration_XXXXX или vault_policies/vault_roles в hosts.yaml.
#   - external_secret_name и target_secret_name в _extra НЕ должны совпадать
#     с уже определёнными в hosts.yaml для того же компонента.
#   - При конфликте имён playbook упадёт с ошибкой.
# =============================================================================

all:
  vars:
    # Временные S3-секреты для Longhorn disaster recovery (без Vault/ESO)
    # Используются playbook-ами longhorn-s3-restore-create.yaml / longhorn-s3-restore-delete.yaml
    longhorn_s3_restore_secrets: []
    # Пример:
    # longhorn_s3_restore_secrets:
    #   - name: "longhorn-s3-backup-creds"
    #     data:
    #       AWS_ACCESS_KEY_ID: "my-access-key"
    #       AWS_SECRET_ACCESS_KEY: "my-secret-key"
    #       AWS_ENDPOINTS: "https://s3.example.com"
    #       AWS_REGION: "us-east-1"

    # Дополнительные политики Vault (не связанные с ESO интеграциями)
    vault_policies_extra: []
    # Пример:
    # vault_policies_extra:
    #   - name: my-custom-policy
    #     paths:
    #       - path: secret/data/my-app/*
    #         capabilities: [read, list]
    #       - path: secret/metadata/my-app/*
    #         capabilities: [read, list]

    # Дополнительные роли Vault (не связанные с ESO интеграциями)
    vault_roles_extra: []
    # Пример:
    # vault_roles_extra:
    #   - name: my-app-role
    #     namespace: my-app
    #     sa_name: my-app-sa
    #     policies:
    #       - my-custom-policy

    # Дополнительные ExternalSecrets для Vault self
    eso_vault_integration_vault_extra:
      secrets: []
    # Пример:
    # eso_vault_integration_vault_extra:
    #   secrets:
    #     - external_secret_name: "eso-vault-custom"
    #       target_secret_name: "eso-vault-custom"
    #       vault_path: "/vault/custom/creds"
    #       refresh_interval: "1m"
    #       type: "default"
    #       # is_need_eso: false  # vault-only: не создавать ExternalSecret и Vault-политику для этого секрета
    #                             # vault_path по-прежнему доступен в плейбуках (default: true)

    # Дополнительные ExternalSecrets для Traefik
    eso_vault_integration_traefik_extra:
      secrets: []
    # Пример:
    # eso_vault_integration_traefik_extra:
    #   secrets:
    #     - external_secret_name: "traefik-custom-cert"
    #       target_secret_name: "traefik-custom-cert"
    #       vault_path: "/traefik/custom/creds"
    #       refresh_interval: "1m"
    #       type: "default"

    # Дополнительные ExternalSecrets для HAProxy
    eso_vault_integration_haproxy_extra:
      secrets: []
    # Пример:
    # eso_vault_integration_haproxy_extra:
    #   secrets:
    #     - external_secret_name: "haproxy-custom-secret"
    #       target_secret_name: "haproxy-custom-secret"
    #       vault_path: "/haproxy/custom/creds"
    #       refresh_interval: "1m"
    #       type: "default"

    # Дополнительные ExternalSecrets для Longhorn (S3-backup credentials)
    eso_vault_integration_longhorn_extra:
      secrets: []
    # Пример:
    # eso_vault_integration_longhorn_extra:
    #   secrets:
    #     - external_secret_name: "s3-backup"
    #       target_secret_name: "longhorn-s3-backup-creds"
    #       vault_path: "/longhorn-system/s3-backup"
    #       refresh_interval: "1m"
    #       type: "default"

    # Дополнительные ExternalSecrets для GitLab
    eso_vault_integration_gitlab_extra:
      secrets: []
    # Пример (type: "default" для обычных секретов без ESO-шаблона):
    # eso_vault_integration_gitlab_extra:
    #   secrets:
    #     - external_secret_name: "eso-gitlab-custom"
    #       target_secret_name: "eso-gitlab-custom"
    #       vault_path: "/gitlab/custom/creds"
    #       refresh_interval: "1m"
    #       type: "default"

    # Дополнительные ExternalSecrets для ArgoCD
    eso_vault_integration_argocd_extra:
      secrets: []
    # Пример (все доступные типы):
    # eso_vault_integration_argocd_extra:
    #   secrets:
    #
    #     # ── type: default ──────────────────────────────────────────────────────
    #     # Произвольный секрет (dataFrom extract), без ArgoCD-специфичных labels
    #     - external_secret_name: "eso-argocd-custom"
    #       target_secret_name: "eso-argocd-custom"
    #       vault_path: "/argocd/custom/creds"
    #       refresh_interval: "1m"
    #       type: "default"
    #
    #     # ── type: git_ops_repo_pattern ─────────────────────────────────────────
    #     # SSH-ключ, label: repo-creds (credential template для URL-префикса)
    #     # Vault path must contain: repo_url, ssh_private_key
    #     - external_secret_name: "eso-argocd-repo-creds-gitlab"
    #       target_secret_name: "eso-argocd-repo-creds-gitlab"
    #       vault_path: "/argocd/repo-creds-gitlab/creds"
    #       refresh_interval: "1m"
    #       type: "git_ops_repo_pattern"
    #
    #     # ── type: git_ops_repo_direct ──────────────────────────────────────────
    #     # SSH-ключ, label: repository (конкретный репозиторий)
    #     # Vault path must contain: repo_url, ssh_private_key
    #     - external_secret_name: "eso-argocd-my-repo-ssh"
    #       target_secret_name: "eso-argocd-my-repo-ssh"
    #       vault_path: "/argocd/my-repo-ssh/creds"
    #       refresh_interval: "1m"
    #       type: "git_ops_repo_direct"
    #
    #     # ── type: git_ops_repo_direct_userpass ────────────────────────────────
    #     # Username+password, label: repository (конкретный репозиторий)
    #     # Vault path must contain: repo_url, username, password, repo_type (git | helm)
    #     - external_secret_name: "eso-argocd-my-repo-https"
    #       target_secret_name: "eso-argocd-my-repo-https"
    #       vault_path: "/argocd/my-repo-https/creds"
    #       refresh_interval: "1m"
    #       type: "git_ops_repo_direct_userpass"
    #
    #     # ── type: git_ops_repo_pattern_userpass ───────────────────────────────
    #     # Username+password, label: repo-creds (credential template для URL-префикса)
    #     # Vault path must contain: repo_url, username, password, repo_type (git | helm)
    #     - external_secret_name: "eso-argocd-repo-creds-https"
    #       target_secret_name: "eso-argocd-repo-creds-https"
    #       vault_path: "/argocd/repo-creds-https/creds"
    #       refresh_interval: "1m"
    #       type: "git_ops_repo_pattern_userpass"
    #
    #     # ── type: helm_repo ───────────────────────────────────────────────────
    #     # Helm chart repository, label: repository
    #     # Vault path must contain: name, repo_url, username, password
    #     # username/password могут быть пустыми строками для публичных репо
    #     - external_secret_name: "eso-argocd-helm-argo"
    #       target_secret_name: "eso-argocd-helm-argo"
    #       vault_path: "/argocd/helm-argo/creds"
    #       refresh_interval: "1m"
    #       type: "helm_repo"
    #
    #     # ── type: helm_repo_oci ───────────────────────────────────────────────
    #     # OCI-реестр как источник Helm-чартов (enableOCI: "true"), label: repository
    #     # Vault path must contain: name, repo_url, username, password
    #     # username/password могут быть пустыми строками для публичных реестров
    #     - external_secret_name: "eso-argocd-helm-oci-registry"
    #       target_secret_name: "eso-argocd-helm-oci-registry"
    #       vault_path: "/argocd/helm-oci-registry/creds"
    #       refresh_interval: "1m"
    #       type: "helm_repo_oci"

    # ArgoCD ConfigMaps — расширение кастомными ключами
    # Каждая переменная независима: можно переопределить только нужную в hosts-extra.yaml
    # Заполнить ssh_known_hosts после установки GitLab:
    #   kubectl exec -n argocd deploy/argocd-repo-server -- ssh-keyscan -p 3714 gitlab-gitlab-shell.gitlab.svc.cluster.local
    argocd_cm_ssh_known_hosts_extra: []
    argocd_cm_extra: {}
    argocd_cm_cmd_params_extra: {}
    argocd_cm_gpg_keys_extra: {}
    argocd_cm_notifications_extra: {}
    argocd_cm_rbac_extra: {}
    argocd_cm_tls_certs_extra: {}
    # Пример: добавить SSH ключи GitLab (переопределить только эту переменную)
    # argocd_cm_ssh_known_hosts_extra:
    #   - "[gitlab-gitlab-shell.gitlab.svc.cluster.local]:3714 ecdsa-sha2-nistp256 AAAA..."
    #   - "[gitlab-gitlab-shell.gitlab.svc.cluster.local]:3714 ssh-ed25519 AAAA..."
    #   - "[gitlab-gitlab-shell.gitlab.svc.cluster.local]:3714 ssh-rsa AAAA..."
    # Пример: добавить только RBAC политики
    # argocd_cm_rbac_extra:
    #   policy.default: "role:readonly"

    # Переопределение ArgoCD git-ops приложений (заменяет argocd_git_ops_apps из hosts.yaml целиком)
    # argocd_git_ops_apps:
    #   - name: "root-app-of-apps"
    #     project:
    #       sourceRepos: ["*"]
    #       sourceNamespaces: ["*"]
    #       destinations:
    #         - name: "*"
    #           namespace: "*"
    #           server: "*"
    #       clusterResourceBlacklist:
    #         - group: "*"
    #           kind: "*"
    #       namespaceResourceBlacklist:
    #         - group: "argoproj.io"
    #           kind: "AppProject"
    #         - group: "argoproj.io"
    #           kind: "Application"
    #     app:
    #       repoURL: "ssh://git@gitlab-gitlab-shell.gitlab.svc.cluster.local:3714/server/git-ops.git"
    #       targetRevision: "master"
    #       path: "argocd-system"
    #       destinationServer: "https://kubernetes.default.svc"
    #       revisionHistoryLimit: 3
    #     retry:
    #       limit: 5
    #       backoff:
    #         duration: "20s"
    #         factor: 1
    #         maxDuration: "30s"
